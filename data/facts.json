  "seasonal_survival_scope": {
    "summary": "四季生存库只覆盖一年内基础生存，不覆盖完整百科。秋季是建设窗口，冬季是保暖/长夜窗口，春季是雨湿窗口，夏季是降温/防火窗口。",
    "season_to_primary_chain": [
      {"season": "autumn", "primary_chain": "buildout_chain", "focus": "科技、基地、锅、火源、基础战斗和下季准备。"},
      {"season": "winter", "primary_chain": "warmth_chain", "focus": "暖石、御寒装备、火源、燃料和冬季食物路线。"},
      {"season": "spring", "primary_chain": "rain_wetness_chain", "focus": "雨具、避雷、潮湿控制、青蛙雨/发情牛群避险和替代食物路线。"},
      {"season": "summer", "primary_chain": "cooling_and_fireproof_chain", "focus": "冷火、冷暖石、防暑装备、基地防火、食物保鲜和避免自燃。"}
    ],
    "source_ids": ["wiki_autumn", "wiki_winter", "wiki_spring", "wiki_summer", "wiki_wetness", "wiki_overheating"]
  },
  "death_logic_framework": {
    "summary": "冬季/首冬死亡根因按三条链判断：保暖链、食物链、光源链。四季总模型见 seasonal_survival_scope 和 data/seasonal_survival.json。血量/饥饿/理智是实时结果，不能替代链状态。",
    "chains": [
      {
        "id": "warmth_chain",
        "name_zh": "保暖链",
        "break_path": "没有御寒装备/暖石/火源/燃料 -> 体温降低 -> 冻结 -> 血量持续扣减 -> 冻死",
        "observable_ui_result": ["血量下降"],
        "winter_specific": true
      },
      {
        "id": "food_chain",
        "name_zh": "食物链",
        "break_path": "冬季食物来源断裂 -> 饥饿值归零 -> 血量持续扣减；同时迫使玩家远行，拖累保暖链和光源链",
        "observable_ui_result": ["饥饿值下降", "血量下降"],
        "winter_specific": false
      },
      {
        "id": "light_chain",
        "name_zh": "光源链",
        "break_path": "长夜/黑暗/燃料不足 -> 理智持续下降或 Charlie 攻击 -> 暗影生物出现 -> 被打掉血",
        "observable_ui_result": ["理智下降", "血量下降"],
        "winter_specific": false,
        "winter_reason": "冬季昼短夜长，让光源和理智问题更容易变成死亡。"
      }
    ],
    "agent_collection_rule": "Agent 应优先收集链状态：有没有御寒装备和暖石、食物储备和来源是否稳定、光源和燃料如何规划。三维数值只用于判断当前是否需要立即救急。"
  },
